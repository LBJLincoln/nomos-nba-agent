{
  "name": "NBA Quant GPU Runner",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "postCreateCommand": "pip install scikit-learn>=1.5 xgboost lightgbm catboost numpy pandas scipy optuna supabase",
  "secrets": {
    "DATABASE_URL": {
      "description": "Supabase PostgreSQL connection string"
    }
  },
  "customizations": {
    "codespaces": {
      "machine": "standardLinux"
    }
  }
}
